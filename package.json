{
  "name": "freelance-os",
  "version": "0.2.1",
  "mcpName": "io.github.sohlin2/freelance-os",
  "description": "AI-powered freelance business manager for Claude Code. Proposals, invoices, time tracking, scope management, and follow-ups — 37 tools, 5 coaching skills.",
  "type": "module",
  "main": "dist/server.js",
  "license": "MIT",
  "author": {
    "name": "Jacob Sohlin",
    "email": "jacobsohlin@proton.me",
    "url": "https://github.com/Sohlin2"
  },
  "homepage": "https://github.com/Sohlin2/freelance-os",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sohlin2/freelance-os"
  },
  "keywords": [
    "freelance",
    "crm",
    "proposals",
    "invoices",
    "mcp",
    "mcp-server",
    "claude-code",
    "plugin",
    "time-tracking",
    "scope-management",
    "ai"
  ],
  "files": [
    "dist/",
    ".claude-plugin/",
    "skills/",
    ".mcp.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-plugin.js",
    "start": "node dist/server.js",
    "prepublishOnly": "npm run build",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push",
    "db:types": "npx supabase gen types typescript --local > src/types/database.ts",
    "test:db": "npx supabase test db",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@supabase/supabase-js": "^2.100.1",
    "express": "^5.2.1",
    "stripe": "^17.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "supabase": "^2.84.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
