{
  "name": "freelance-os",
  "version": "0.1.0",
  "description": "Freelance business manager for Claude Code — proposals, invoices, follow-ups, scope, and time tracking",
  "type": "module",
  "license": "MIT",
  "author": "FreelanceOS",
  "repository": {
    "type": "git",
    "url": "https://github.com/freelance-os/freelance-os"
  },
  "keywords": ["freelance", "crm", "proposals", "invoices", "mcp", "claude-code", "plugin"],
  "files": [
    ".claude-plugin/",
    "skills/",
    ".mcp.json",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-plugin.js",
    "prepublishOnly": "npm run build",
    "db:reset": "npx supabase db reset",
    "db:push": "npx supabase db push",
    "db:types": "npx supabase gen types typescript --local > src/types/database.ts",
    "test:db": "npx supabase test db",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@supabase/supabase-js": "^2.100.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "supabase": "^2.84.4",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
